# Firebase Configuration - Demo/Development Values
# For production, replace with real Firebase project values

# Firebase API Key
EXPO_PUBLIC_FIREBASE_API_KEY=demo-api-key

# Firebase Auth Domain (usually projectId.firebaseapp.com)
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=island-rides-demo.firebaseapp.com

# Firebase Project ID
EXPO_PUBLIC_FIREBASE_PROJECT_ID=island-rides-demo

# Firebase Storage Bucket (usually projectId.appspot.com)
EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=island-rides-demo.appspot.com

# Firebase Messaging Sender ID
EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789

# Firebase App ID
EXPO_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abcdef123456789

# API Configuration
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
EXPO_PUBLIC_API_PORT=3003
EXPO_PUBLIC_WS_URL=ws://localhost:3001
EXPO_PUBLIC_WS_PORT=3004

# Google Maps Configuration
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyCQyTN8JwsBJ-_UPpbHBaYMILR5-9wTRpU