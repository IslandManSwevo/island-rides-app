# KeyLo API — Railway service variables (design/04-backend-architecture.md)
# DATABASE_URL and REDIS_URL are injected by Railway plugins in production.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/keylo
JWT_SECRET=change-me-32-chars-minimum-secret
JWT_REFRESH_SECRET=change-me-too-32-chars-minimum
APP_ORIGIN=http://localhost:8081

REDIS_URL=

# Cloudflare R2 (object storage — photos, documents)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# PayPal (interim payment rail)
PAYPAL_ENV=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# Expo push
EXPO_ACCESS_TOKEN=
